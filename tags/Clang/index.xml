&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>	printf(&lt;span style="color:#5af78e">&amp;#34;%ld%10s%10.2f&lt;/span>&lt;span style="color:#5af78e">\n&lt;/span>&lt;span style="color:#5af78e">&amp;#34;&lt;/span>,p&lt;span style="color:#ff6ac1">-&amp;gt;&lt;/span>num,p&lt;span style="color:#ff6ac1">-&amp;gt;&lt;/span>name,p&lt;span style="color:#ff6ac1">-&amp;gt;&lt;/span>score);
